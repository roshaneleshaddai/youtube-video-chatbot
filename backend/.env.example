# Copy this file to .env and set your actual values.
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_MODEL=models/gemini-3.1-pro-preview
GEMINI_FALLBACK_MODELS=models/gemini-3.1-pro-preview,models/gemini-3-pro-preview,models/gemini-3.1-flash-lite-preview,models/gemini-2.5-flash
MAX_PROMPT_CHARS=22000

# Optional logging controls
LOG_LEVEL=INFO
THIRD_PARTY_LOG_LEVEL=WARNING
